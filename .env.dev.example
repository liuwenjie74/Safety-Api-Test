# Test environment example.
ENV=dev
BASE_URL=http://test.lenszl.cn:30275
LOGIN_URL=http://test.lenszl.cn:30275/api/common/sys/login
LOGIN_METHOD=POST
LOGIN_HEADERS={"Content-Type":"application/json"}
LOGIN_PAYLOAD={"userAccount":"YOUR_TEST_ACCOUNT","password":"YOUR_TEST_PASSWORD"}

TOKEN_PATH=data
TOKEN_HEADER=token
TOKEN_PREFIX=
REQUEST_TIMEOUT=15
EXCEL_MAIN=api_cases.xlsx
MASK_TOKEN_VISIBLE=4
