# Production environment example.
ENV=prod
BASE_URL=https://jdz.lenszl.cn
LOGIN_URL=https://jdz.lenszl.cn/api/common/sys/login
LOGIN_METHOD=POST
LOGIN_HEADERS={"Content-Type":"application/json"}
LOGIN_PAYLOAD={"userAccount":"YOUR_PROD_ACCOUNT","password":"YOUR_PROD_PASSWORD"}

TOKEN_PATH=data
TOKEN_HEADER=token
TOKEN_PREFIX=
REQUEST_TIMEOUT=15
EXCEL_MAIN=api_cases.xlsx
MASK_TOKEN_VISIBLE=4
